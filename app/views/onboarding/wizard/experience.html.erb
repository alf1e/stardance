<% content_for :title, "Experience" %>
<main class="onboarding-screen onboarding-screen--experience" data-controller="onboarding-transition">
  <%= render Onboarding::ProgressBarComponent.new(step: :experience) %>

  <div class="onboarding-screen__content">
    <h1 class="onboarding-screen__title">How much have you made on your own before?</h1>
    <p class="onboarding-screen__subhead">Coding experience, hardware projects, anything technical. There's no wrong answer, and we'll use this to tailor your experience to your better!</p>

    <%= form_with url: onboarding_experience_path, method: :post, local: true,
                   class: "onboarding-experience__form" do %>
      <div class="onboarding-experience__cards">
        <% [
          [ "none",        "Total beginner, never really coded or built anything" ],
          [ "little",      "I've done some school stuff, but never on my own" ],
          [ "some",        "I've made a project or two on my own :)" ],
          [ "experienced", "I'm always building something!" ]
        ].each do |value, label| %>
          <%= render ActionButtonComponent.new(
                text: label,
                variant: :secondary,
                size: :large,
                surface: :dark,
                type: :submit,
                name: "level",
                value: value,
                data: { action: "click->onboarding-transition#press" }
              ) %>
        <% end %>
      </div>
    <% end %>
  </div>
</main>
